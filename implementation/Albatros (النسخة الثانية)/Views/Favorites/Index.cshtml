@model IEnumerable<Albatros.Models.Favorite>
@{
    ViewData["Title"] = "My Favorites";
}

<div class="wrap" style="padding: 40px 0 80px;">
    <div style="margin-bottom: 30px;">
        <div class="eyebrow" data-i18n="saved_list">SAVED COLLECTION</div>
        <h1 style="font-size: 32px; font-family: 'Playfair Display', serif;" data-i18n="fav_title">My Favorite Properties</h1>
    </div>

    <div class="cards-strip">
        <div class="cards-row">
            @if (Model != null && Model.Any())
            {
                @foreach (var fav in Model)
                {
                    if (fav.Property != null)
                    {
                        <div style="position: relative;">
                            @await Html.PartialAsync("_PropertyCard", fav.Property)
                            <form asp-controller="Favorites" asp-action="Remove" method="post" style="position: absolute; top: 16px; right: 16px; z-index: 10;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@fav.FavoriteId" />
                                <button type="submit" style="background: white; border: none; border-radius: 50%; width: 36px; height: 36px; box-shadow: 0 2px 8px rgba(0,0,0,0.15); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px;" title="Remove from Favorites">
                                    🗑️
                                </button>
                            </form>
                        </div>
                    }
                }
            }
            else
            {
                <div style="background: white; border-radius: 16px; padding: 60px 20px; text-align: center; border: 1px solid #EFEDE9; width: 100%;">
                    <div style="font-size: 40px; margin-bottom: 16px;">🤍</div>
                    <h3 style="font-size: 20px; margin-bottom: 8px;" data-i18n="no_favs">You haven't saved any favorites yet</h3>
                    <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;" data-i18n="start_fav">Explore our active property listings and click the heart icon to save listings here for easy reference.</p>
                    <a asp-controller="Properties" asp-action="Index" class="btn btn-maroon" data-i18n="browse_now">Browse Properties Now</a>
                </div>
            }
        </div>
    </div>
</div>
