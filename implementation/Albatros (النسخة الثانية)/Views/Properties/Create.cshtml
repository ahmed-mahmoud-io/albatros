@model Albatros.Models.Property
@{
    ViewData["Title"] = "Add Property";
}

@section Styles {
<style>
    .form-box { background: white; border-radius: 16px; padding: 40px; border: 1px solid #EFEDE9; box-shadow: 0 4px 20px rgba(0,0,0,0.03); max-width: 800px; margin: 30px auto 60px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .field { margin-bottom: 20px; }
    .field.full { grid-column: span 2; }
    .field label { display: block; font-size: 12px; font-weight: 600; color: #5A5A5A; margin-bottom: 8px; text-transform: uppercase; }
    .field input, .field select, .field textarea { width: 100%; padding: 12px 14px; border-radius: 8px; border: 1px solid var(--gray-mid); background: var(--gray-bg); font-size: 14px; }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: var(--maroon); background: white; outline: none; }
    @@media (max-width: 700px) { .form-grid { grid-template-columns: 1fr; } .field.full { grid-column: span 1; } }
</style>
}

<div class="wrap">
    <div class="form-box">
        <div class="eyebrow" data-i18n="add_prop_eyebrow">NEW LISTING</div>
        <h1 style="font-size: 28px; font-family: 'Playfair Display', serif; margin-bottom: 24px;" data-i18n="add_prop_title">List Your Property</h1>

        <form asp-controller="Properties" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-grid">
                <div class="field full">
                    <label asp-for="Title" data-i18n="title">Property Title</label>
                    <input asp-for="Title" type="text" placeholder="Luxury Villa in Olaya District" required />
                </div>

                <div class="field">
                    <label asp-for="Price" data-i18n="price">Price (SAR)</label>
                    <input asp-for="Price" type="number" step="1000" placeholder="2500000" required />
                </div>

                <div class="field">
                    <label asp-for="City" data-i18n="city">City</label>
                    <select asp-for="City" asp-items="@(new SelectList(ViewBag.Cities ?? new List<string> { "Riyadh", "Jeddah", "Mecca", "Dammam", "Khobar" }))" required>
                        <option value="" data-i18n="select_city">-- Select City --</option>
                    </select>
                </div>

                <div class="field">
                    <label asp-for="Bedrooms" data-i18n="bedrooms">Bedrooms</label>
                    <input asp-for="Bedrooms" type="number" min="0" value="3" required />
                </div>

                <div class="field">
                    <label asp-for="Bathrooms" data-i18n="bathrooms">Bathrooms</label>
                    <input asp-for="Bathrooms" type="number" min="0" value="3" required />
                </div>

                <div class="field">
                    <label asp-for="Area" data-i18n="area">Area (Square Meters)</label>
                    <input asp-for="Area" type="number" step="0.01" placeholder="450" required />
                </div>

                <div class="field">
                    <label data-i18n="images">Upload Images</label>
                    <input type="file" name="images" multiple accept="image/*" />
                </div>

                <div class="field full">
                    <label asp-for="Description" data-i18n="description">Detailed Description</label>
                    <textarea asp-for="Description" rows="5" placeholder="Highlight key features, finishes, proximity to landmarks..." required></textarea>
                </div>
            </div>

            <div style="display:flex; gap:16px; margin-top:20px;">
                <button type="submit" class="btn btn-maroon" style="padding: 14px 32px;" data-i18n="submit_listing">Submit Listing</button>
                <a asp-controller="Properties" asp-action="Index" class="btn btn-ghost" style="padding: 14px 24px;" data-i18n="cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>
