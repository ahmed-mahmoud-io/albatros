@model Albatros.Models.VisitRequest
@{
    ViewData["Title"] = "Cancel Visit Request";
}

<div class="wrap" style="padding: 60px 0;">
    <div style="background: white; border-radius: 16px; padding: 40px; max-width: 550px; margin: 0 auto; border: 1px solid #FFCDD2; box-shadow: 0 4px 20px rgba(0,0,0,0.04); text-align: center;">
        <div style="font-size: 50px; margin-bottom: 16px;">🗓️</div>
        <h1 style="font-size: 26px; font-family: 'Playfair Display', serif; color: #C62828; margin-bottom: 12px;" data-i18n="cancel_visit_title">Cancel Private Viewing</h1>
        <p style="color: var(--text-muted); margin-bottom: 24px; line-height: 1.6;" data-i18n="cancel_visit_desc">
            Are you sure you want to cancel your scheduled visit for <strong style="color:var(--black);">@(Model.Property?.Title ?? "this property")</strong>?
        </p>

        <div style="background: var(--gray-bg); padding: 16px; border-radius: 10px; margin-bottom: 28px; text-align: left; font-size: 14px;">
            <div><strong>Scheduled Date:</strong> @Model.VisitDate.ToString("dddd, MMM dd, yyyy")</div>
            <div style="margin-top:4px;"><strong>Time Slot:</strong> @Model.VisitDate.ToString("hh:mm tt")</div>
        </div>

        <form asp-controller="VisitRequests" asp-action="Delete" asp-route-id="@Model.RequestId" method="post">
            @Html.AntiForgeryToken()
            <div style="display: flex; gap: 12px; justify-content: center;">
                <button type="submit" class="btn" style="background: #D32F2F; color: white; padding: 12px 28px;" data-i18n="btn_confirm_cancel">Yes, Cancel Visit</button>
                <a asp-controller="VisitRequests" asp-action="Details" asp-route-id="@Model.RequestId" class="btn btn-ghost" style="padding: 12px 24px;" data-i18n="keep_visit">Keep Request</a>
            </div>
        </form>
    </div>
</div>
