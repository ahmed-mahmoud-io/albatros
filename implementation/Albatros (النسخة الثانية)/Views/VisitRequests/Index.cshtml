@model IEnumerable<Albatros.Models.VisitRequest>
@{
    ViewData["Title"] = "My Visit Requests";
}

@section Styles {
<style>
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .status-Pending { background: #FFF8E1; color: #F57F17; }
    .status-Approved { background: #E8F5E9; color: #2E7D32; }
    .status-Rejected { background: #FFEBEE; color: #C62828; }
    .my-table { width: 100%; border-collapse: collapse; background: white; border-radius: 16px; overflow: hidden; border: 1px solid #EFEDE9; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
    .my-table th { background: var(--gray-bg); padding: 16px; text-align: left; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid #EFEDE9; }
    .my-table td { padding: 18px 16px; border-bottom: 1px solid #EFEDE9; vertical-align: middle; }
    .my-table tr:last-child td { border-bottom: none; }
</style>
}

<div class="wrap" style="padding: 40px 0 80px;">
    <div style="margin-bottom: 30px;">
        <div class="eyebrow" data-i18n="private_viewings">PRIVATE VIEWINGS</div>
        <h1 style="font-size: 32px; font-family: 'Playfair Display', serif;" data-i18n="visits_title">My Scheduled Visit Requests</h1>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="my-table">
            <thead>
                <tr>
                    <th data-i18n="property">Property</th>
                    <th data-i18n="visit_date">Visit Date & Time</th>
                    <th data-i18n="status">Request Status</th>
                    <th style="text-align: right;" data-i18n="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: 600;">
                            <a asp-controller="Properties" asp-action="Details" asp-route-id="@item.PropertyId" style="color: inherit; text-decoration: none;">@(item.Property?.Title ?? "Property #" + item.PropertyId)</a>
                        </td>
                        <td style="color: var(--black); font-weight: 500;">
                            📅 @item.VisitDate.ToString("dddd, MMM dd, yyyy - hh:mm tt")
                        </td>
                        <td>
                            <span class="status-badge status-@item.Status">@item.Status</span>
                        </td>
                        <td style="text-align: right;">
                            <a asp-controller="VisitRequests" asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-ghost" style="padding: 6px 12px; font-size: 12px;">Details</a>
                            <a asp-controller="VisitRequests" asp-action="Delete" asp-route-id="@item.RequestId" class="btn" style="padding: 6px 12px; font-size: 12px; background: #FFEBEE; color: #C62828;">Cancel</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="background: white; border-radius: 16px; padding: 60px 20px; text-align: center; border: 1px solid #EFEDE9;">
            <div style="font-size: 40px; margin-bottom: 16px;">🗓️</div>
            <h3 style="font-size: 20px; margin-bottom: 8px;" data-i18n="no_visits">No scheduled visit requests found</h3>
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;" data-i18n="schedule_info">Navigate through our luxury property listings and book a private tour with our senior advisors.</p>
            <a asp-controller="Properties" asp-action="Index" class="btn btn-maroon" data-i18n="browse_now">Explore Properties Now</a>
        </div>
    }
</div>
