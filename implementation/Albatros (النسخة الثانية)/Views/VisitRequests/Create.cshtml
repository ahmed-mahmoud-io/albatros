@model Albatros.Models.VisitRequest
@{
    ViewData["Title"] = "Book a Visit";
}

<div class="wrap" style="padding: 40px 0 80px;">
    <div style="background: white; border-radius: 16px; padding: 40px; max-width: 600px; margin: 0 auto; border: 1px solid #EFEDE9; box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
        <div class="eyebrow" data-i18n="private_tour">PRIVATE VIEWING TOUR</div>
        <h1 style="font-size: 28px; font-family: 'Playfair Display', serif; margin-bottom: 24px;" data-i18n="book_visit_t">Schedule Property Visit</h1>

        <form asp-controller="VisitRequests" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PropertyId" />

            <div class="field" style="margin-bottom: 28px;">
                <label asp-for="VisitDate" style="display: block; font-size: 12px; font-weight: 600; color: #5A5A5A; margin-bottom: 8px; text-transform: uppercase;" data-i18n="select_datetime">Select Preferred Date & Time</label>
                <input asp-for="VisitDate" type="datetime-local" value="@Model.VisitDate.ToString("yyyy-MM-ddTHH:mm")" style="width: 100%; padding: 14px 16px; border-radius: 8px; border: 1px solid var(--gray-mid); background: var(--gray-bg); font-size: 15px;" required />
                <span style="display: block; font-size: 12px; color: var(--text-muted); margin-top: 6px;">Advisors are available from 9:00 AM to 6:00 PM daily.</span>
            </div>

            <div style="display: flex; gap: 16px;">
                <button type="submit" class="btn btn-maroon" style="padding: 14px 32px; flex: 1;" data-i18n="confirm_booking">Confirm Viewing Request</button>
                <a asp-controller="Properties" asp-action="Details" asp-route-id="@Model.PropertyId" class="btn btn-ghost" style="padding: 14px 24px;" data-i18n="cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>
