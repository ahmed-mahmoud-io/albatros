@model IEnumerable<Albatros.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

@section Styles {
<style>
    .notif-list { max-width: 700px; margin: 30px auto 60px; }
    .notif-item { display: flex; align-items: flex-start; gap: 14px; padding: 16px 20px; border-radius: 12px; border: 1px solid #EFEDE9; margin-bottom: 10px; transition: background .2s; }
    .notif-item.unread { background: #FFF8F0; border-color: #F0DCC0; }
    .notif-item:hover { background: #F8F8F8; }
    .notif-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--maroon); flex-shrink: 0; margin-top: 6px; }
    .notif-item.read .notif-dot { background: #D0D0D0; }
    .notif-body { flex: 1; }
    .notif-msg { font-size: 14px; line-height: 1.5; margin-bottom: 4px; }
    .notif-time { font-size: 12px; color: var(--text-muted); }
</style>
}

<div class="wrap">
    <div class="notif-list">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
            <h1 style="font-size: 28px; font-family: 'Playfair Display', serif; margin:0;">Notifications</h1>
            @if (Model != null && Model.Any())
            {
                <button id="clearAllBtn" style="background:none; border:1px solid #ccc; border-radius:8px; padding:8px 16px; font-size:13px; cursor:pointer; color:#9C2A2A;">Clear All</button>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            @foreach (var n in Model)
            {
                <div class="notif-item @(n.IsRead ? "read" : "unread")" data-id="@n.Id">
                    <div class="notif-dot"></div>
                    <div class="notif-body">
                        <div class="notif-msg">
                            @if (!string.IsNullOrEmpty(n.LinkUrl))
                            {
                                <a href="@n.LinkUrl" style="color:inherit; text-decoration:none;">@n.Message</a>
                            }
                            else
                            {
                                @n.Message
                            }
                        </div>
                        <div class="notif-time">@n.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</div>
                    </div>
                </div>
            }
        }
        else
        {
            <p style="text-align:center; padding:60px 0; color:var(--text-muted);">No notifications yet.</p>
        }
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.notif-item.unread').forEach(function(el) {
        el.addEventListener('click', function() {
            var id = el.getAttribute('data-id');
            fetch('/Notifications/MarkRead', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + id
            });
            el.classList.remove('unread');
            el.classList.add('read');
        });
    });

    document.getElementById('clearAllBtn')?.addEventListener('click', function() {
        if (!confirm('Clear all notifications?')) return;
        fetch('/Notifications/DeleteAll', { method: 'POST' })
            .then(function(r) {
                if (r.ok) {
                    document.querySelectorAll('.notif-item').forEach(function(el) { el.remove(); });
                    document.querySelector('.notif-list').insertAdjacentHTML('beforeend', '<p style="text-align:center; padding:60px 0; color:var(--text-muted);">No notifications yet.</p>');
                    document.getElementById('clearAllBtn').remove();
                }
            });
    });
</script>
}
