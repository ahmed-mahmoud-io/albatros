@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تم تغيير كلمة المرور - ALBATROS</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --maroon: #9C2A2A;
            --maroon-dark: #7A2020;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --gray-bg: #F8F8F8;
            --gray-mid: #E4E1DC;
            --text-muted: #8A8580;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Cairo', sans-serif; }
        body { background: var(--gray-bg); color: var(--black); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .confirm-box { background: var(--white); border-radius: 16px; padding: 40px; max-width: 500px; width: 100%; text-align: center; border: 1px solid var(--gray-mid); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .icon { font-size: 60px; margin-bottom: 24px; color: #2E7D32; }
        h1 { font-family: 'Playfair Display', 'Cairo', serif; font-size: 28px; font-weight: 700; margin-bottom: 16px; color: var(--black); }
        p { color: var(--text-muted); font-size: 15px; line-height: 1.8; margin-bottom: 30px; }
        .btn-maroon { display: inline-block; width: 100%; padding: 14px; background: var(--maroon); color: white; border: none; border-radius: 10px; font-weight: 600; font-size: 15px; cursor: pointer; text-decoration: none; transition: background 0.2s; }
        .btn-maroon:hover { background: var(--maroon-dark); }
    </style>
</head>
<body>
    <div class="confirm-box">
        <div class="icon">✅</div>
        <h1>تغيير كلمة المرور</h1>
        <p>تم إعادة تعيين كلمة المرور الخاصة بك بنجاح! يمكنك الآن تسجيل الدخول إلى حسابك باستخدام كلمة المرور الجديدة.</p>
        
        <a href="/Account/Login" class="btn-maroon">تسجيل الدخول الآن</a>
    </div>
</body>
</html>
