@model Albatros.Models.ViewModels.ResetPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تعيين كلمة المرور - ALBATROS</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --maroon: #9C2A2A;
            --maroon-dark: #7A2020;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --gray-bg: #F8F8F8;
            --gray-mid: #E4E1DC;
            --text-muted: #8A8580;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Cairo', 'Inter', sans-serif; }
        body { background: var(--white); color: var(--black); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .auth-box { width: 100%; max-width: 420px; border: 1px solid var(--gray-mid); border-radius: 16px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); }
        .logo-bird { display: flex; align-items: center; justify-content: center; gap: 10px; font-weight: 700; font-size: 20px; letter-spacing: 2px; color: var(--maroon); margin-bottom: 24px; }
        h1 { font-size: 26px; font-weight: 700; margin-bottom: 12px; text-align: center; font-family: 'Playfair Display', 'Cairo', serif; }
        .subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 28px; text-align: center; line-height: 1.6; }
        .field { margin-bottom: 20px; }
        .field label { display: block; font-size: 13px; font-weight: 600; color: #5A5A5A; margin-bottom: 8px; }
        .field input { width: 100%; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--gray-mid); background: var(--gray-bg); font-size: 14px; transition: all 0.2s; text-align: right; }
        .field input:focus { border-color: var(--maroon); background: var(--white); outline: none; box-shadow: 0 0 0 3px rgba(156, 42, 42, 0.1); }
        .btn-maroon { width: 100%; padding: 14px; background: var(--maroon); color: white; border: none; border-radius: 10px; font-weight: 600; font-size: 15px; cursor: pointer; transition: background 0.2s; margin-top: 10px; }
        .btn-maroon:hover { background: var(--maroon-dark); }
        .alert-error { background: #FFEBEE; color: #C62828; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; border: 1px solid #FFCDD2; text-align: center; }
        .validation-summary { color: #C62828; font-size: 13px; margin-bottom: 16px; list-style: none; text-align: right; }
    </style>
</head>
<body>
    <div class="auth-box">
        <div class="logo-bird">
            <svg viewBox="0 0 48 48" width="30" height="30" fill="none"><path d="M24 24 C10 12, 0 15, 3 27 C10 21, 18 22, 24 24 Z" fill="var(--maroon)"/><path d="M24 24 C38 12, 48 15, 45 27 C38 21, 30 22, 24 24 Z" fill="var(--maroon)"/><path d="M17 25 Q24 19 31 25 Q28 30 24 30 Q20 30 17 25 Z" fill="var(--maroon-dark)"/></svg>
            ALBATROS
        </div>
        
        <h1>تعيين كلمة المرور</h1>
        <div class="subtitle">يرجى إدخال البريد الإلكتروني، ورمز التحقق (OTP) المرسل إليك، وكلمة المرور الجديدة.</div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error" style="margin-top: 10px; margin-bottom: 20px;">@ViewBag.Error</div>
        }

        <form asp-controller="Account" asp-action="ResetPassword" method="post" style="text-align: right;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="field">
                <label asp-for="Email">البريد الإلكتروني</label>
                <input asp-for="Email" type="email" placeholder="name@example.com" required style="text-align: right;" />
            </div>

            <div class="field">
                <label asp-for="Token">رمز التحقق (OTP)</label>
                <input asp-for="Token" type="text" placeholder="------" required style="text-align: center; font-weight: bold; letter-spacing: 2px;" autocomplete="off" />
            </div>

            <div class="field">
                <label asp-for="NewPassword">كلمة المرور الجديدة</label>
                <input asp-for="NewPassword" type="password" placeholder="••••••••" required />
            </div>

            <div class="field">
                <label asp-for="ConfirmPassword">تأكيد كلمة المرور الجديدة</label>
                <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-maroon">حفظ كلمة المرور</button>
        </form>
    </div>
</body>
</html>
