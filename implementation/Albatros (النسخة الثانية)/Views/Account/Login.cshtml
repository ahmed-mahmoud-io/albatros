@model Albatros.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-i18n="login_title">Login - ALBATROS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --maroon: #9C2A2A;
            --maroon-dark: #7A2020;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --gray-bg: #F8F8F8;
            --gray-mid: #E4E1DC;
            --text-muted: #8A8580;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', 'Cairo', sans-serif; }
        body { background: var(--white); color: var(--black); min-height: 100vh; display: flex; }
        .auth-section { width: 100%; min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }
        .auth-visual {
            background: linear-gradient(155deg, var(--maroon), var(--maroon-dark));
            color: white;
            padding: 70px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }
        .auth-visual h1 { font-family: 'Playfair Display', serif; font-size: 42px; line-height: 1.2; margin-top: 40px; }
        .auth-visual p { font-size: 16px; opacity: 0.85; margin-top: 16px; max-width: 400px; line-height: 1.6; }
        .auth-form-side { display: flex; align-items: center; justify-content: center; padding: 60px 40px; }
        .auth-box { width: 100%; max-width: 400px; }
        .auth-box h2 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
        .auth-box .subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 32px; }
        .field { margin-bottom: 20px; }
        .field label { display: block; font-size: 12px; font-weight: 600; color: #5A5A5A; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .field input { width: 100%; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--gray-mid); background: var(--gray-bg); font-size: 14px; transition: all 0.2s; }
        .field input:focus { border-color: var(--maroon); background: var(--white); outline: none; box-shadow: 0 0 0 3px rgba(156, 42, 42, 0.1); }
        .btn-maroon { width: 100%; padding: 14px; background: var(--maroon); color: white; border: none; border-radius: 10px; font-weight: 600; font-size: 15px; cursor: pointer; transition: background 0.2s; margin-top: 10px; }
        .btn-maroon:hover { background: var(--maroon-dark); }
        .alert-error { background: #FFEBEE; color: #C62828; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; border: 1px solid #FFCDD2; }
        .auth-links { margin-top: 24px; text-align: center; font-size: 14px; color: var(--text-muted); }
        .auth-links a { color: var(--maroon); text-decoration: none; font-weight: 600; }
        .auth-links a:hover { text-decoration: underline; }
        .remember-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; font-size: 13px; }
        .remember-row label { display: flex; align-items: center; gap: 8px; cursor: pointer; color: #5A5A5A; font-weight: 500; text-transform: none; }
        .remember-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--maroon); }
        .logo-bird { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 20px; letter-spacing: 2px; }
        @@media (max-width: 900px) {
            .auth-section { grid-template-columns: 1fr; }
            .auth-visual { display: none; }
        }
        @@keyframes _bank{0%,100%{transform:rotate(0deg)}25%{transform:rotate(-3deg)}75%{transform:rotate(3deg)}}@@keyframes _wingL{0%,100%{transform:scaleY(1)}50%{transform:scaleY(0.35)}}@@keyframes _wingR{0%,100%{transform:scaleY(1)}50%{transform:scaleY(0.35)}}
    </style>
</head>
<body>
    <div class="auth-section">
        <div class="auth-visual">
            <div>
                <div class="logo-bird">
                    <svg viewBox="0 0 64 34" width="52" height="28" xmlns="http://www.w3.org/2000/svg" style="overflow: visible;">
                        <g style="transform-origin: 32px 18px; animation: _bank 3.4s ease-in-out infinite;">
                            <path d="M31.5 19C21 8.6 9.2 8.3 2.5 13.2C9.5 14.6 18.9 16.4 31.5 19Z" fill="rgba(255,255,255,0.9)" style="transform-box: fill-box; transform-origin: right center; animation: _wingL 1.05s cubic-bezier(0.37,0,0.63,1) infinite;"/>
                            <path d="M32.5 19C43 8.6 54.8 8.3 61.5 13.2C54.5 14.6 45.1 16.4 32.5 19Z" fill="rgba(255,255,255,0.9)" style="transform-box: fill-box; transform-origin: left center; animation: _wingR 1.05s cubic-bezier(0.37,0,0.63,1) infinite;"/>
                            <path d="M23.5 18.8C26.4 15.2 29.3 13.5 32 13.5C34.8 13.5 37.7 15.2 40.5 18.8C38.1 21.5 35.2 22.8 32 22.8C28.8 22.8 25.9 21.5 23.5 18.8Z" fill="rgba(255,255,255,0.6)"/>
                            <ellipse cx="32" cy="10.2" rx="4.6" ry="3.4" fill="rgba(255,255,255,0.6)"/>
                        </g>
                    </svg>
                    ALBATROS
                </div>
                <h1 data-i18n="auth_hero_title">Find a home that understands your ambition.</h1>
                <p data-i18n="auth_hero_sub">Experience Saudi Arabia's premier real estate platform offering verified luxury residences and commercial spaces.</p>
            </div>
            <div style="font-size: 13px; opacity: 0.6;">&copy; 2026 ALBATROS Real Estate. All rights reserved.</div>
        </div>
        <div class="auth-form-side">
            <div class="auth-box">
                <h2 data-i18n="welcome_back">Welcome Back</h2>
                <div class="subtitle" data-i18n="login_subtitle">Please enter your details to sign in</div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert-error">
                        @ViewBag.Error
                        @if (ViewBag.ResendEmail != null)
                        {
                            <br /><br />
                            <a asp-action="ResendVerification" asp-route-email="@ViewBag.ResendEmail" style="color: #B71C1C; font-weight: 700; text-decoration: underline;">إعادة إرسال رابط التفعيل</a>
                        }
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="field">
                        <label asp-for="Email" data-i18n="email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="name@example.com" required />
                        <span asp-validation-for="Email" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Password" data-i18n="password">Password</label>
                        <input asp-for="Password" type="password" placeholder="••••••••" required />
                        <span asp-validation-for="Password" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="remember-row">
                        <label>
                            <input asp-for="RememberMe" type="checkbox" />
                            <span data-i18n="remember_me">Remember me</span>
                        </label>
                        <a asp-action="ForgotPassword" style="color: var(--maroon); text-decoration: none; font-weight: 600;" data-i18n="forgot_password">Forgot Password?</a>
                    </div>
                    <button type="submit" class="btn-maroon" data-i18n="sign_in">Sign In</button>
                </form>

                <div style="display:flex;align-items:center;gap:14px;margin:26px 0;color:var(--text-muted);font-size:12.5px;">
                    <span style="flex:1;height:1px;background:var(--gray-mid);"></span>
                    <span data-i18n="login_or">or continue with</span>
                    <span style="flex:1;height:1px;background:var(--gray-mid);"></span>
                </div>
                <a asp-controller="Account" asp-action="GoogleLogin" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:11px;border-radius:8px;border:1px solid var(--gray-mid);font-size:13px;font-weight:600;color:#4A4A4A;cursor:pointer;background:var(--white);text-decoration:none;margin-bottom:26px;">
                    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.54 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.87 7.35 2.56 10.58l7.98-5.99z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.99C6.51 42.62 14.62 48 24 48z"/></svg>
                    <span>Google</span>
                </a>
                <div class="auth-links">
                    <span data-i18n="no_account">Don't have an account?</span> 
                    <a asp-controller="Account" asp-action="Register" data-i18n="create_account">Create Account</a>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/i18n.js"></script>
</body>
</html>
