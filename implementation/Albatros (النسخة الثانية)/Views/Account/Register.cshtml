@model Albatros.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-i18n="register_title">Register - ALBATROS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --maroon: #9C2A2A;
            --maroon-dark: #7A2020;
            --black: #0A0A0A;
            --white: #FFFFFF;
            --gray-bg: #F8F8F8;
            --gray-mid: #E4E1DC;
            --text-muted: #8A8580;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', 'Cairo', sans-serif; }
        body { background: var(--white); color: var(--black); min-height: 100vh; display: flex; }
        .auth-section { width: 100%; min-height: 100vh; display: grid; grid-template-columns: 1fr 1.2fr; }
        .auth-visual {
            background: linear-gradient(155deg, var(--maroon), var(--maroon-dark));
            color: white;
            padding: 70px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .auth-visual h1 { font-family: 'Playfair Display', serif; font-size: 42px; line-height: 1.2; margin-top: 40px; }
        .auth-visual p { font-size: 16px; opacity: 0.85; margin-top: 16px; max-width: 400px; line-height: 1.6; }
        .auth-form-side { display: flex; align-items: center; justify-content: center; padding: 30px 40px; }
        .auth-box { width: 100%; max-width: 440px; }
        .auth-box h2 { font-size: 26px; font-weight: 700; margin-bottom: 4px; }
        .auth-box .subtitle { color: var(--text-muted); font-size: 13px; margin-bottom: 14px; }
        .field { margin-bottom: 10px; }
        .field label { display: block; font-size: 11px; font-weight: 600; color: #5A5A5A; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
        .field input, .field select { width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid var(--gray-mid); background: var(--gray-bg); font-size: 13px; transition: all 0.2s; }
        .field input:focus, .field select:focus { border-color: var(--maroon); background: var(--white); outline: none; box-shadow: 0 0 0 3px rgba(156, 42, 42, 0.1); }
        .role-tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
        .role-tab { position: relative; }
        .role-tab input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
        .role-tab label { display: flex; align-items: center; justify-content: center; padding: 8px; border: 1.5px solid var(--gray-mid); border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px; transition: all 0.2s; background: var(--gray-bg); text-transform: none; }
        .role-tab input:checked + label { border-color: var(--maroon); background: rgba(156, 42, 42, 0.05); color: var(--maroon); }
        .btn-maroon { width: 100%; padding: 11px; background: var(--maroon); color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: background 0.2s; margin-top: 6px; }
        .btn-maroon:hover { background: var(--maroon-dark); }
        .alert-error { background: #FFEBEE; color: #C62828; padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 12px; border: 1px solid #FFCDD2; }
        .auth-links { margin-top: 14px; text-align: center; font-size: 13px; color: var(--text-muted); }
        .auth-links a { color: var(--maroon); text-decoration: none; font-weight: 600; }
        .auth-links a:hover { text-decoration: underline; }
        .logo-bird { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 20px; letter-spacing: 2px; }
        @@media (max-width: 900px) {
            .auth-section { grid-template-columns: 1fr; }
            .auth-visual { display: none; }
        }
        @@keyframes _bank{0%,100%{transform:rotate(0deg)}25%{transform:rotate(-3deg)}75%{transform:rotate(3deg)}}@@keyframes _wingL{0%,100%{transform:scaleY(1)}50%{transform:scaleY(0.35)}}@@keyframes _wingR{0%,100%{transform:scaleY(1)}50%{transform:scaleY(0.35)}}
    </style>
</head>
<body>
    <div class="auth-section">
        <div class="auth-visual">
            <div>
                <div class="logo-bird">
                    <svg viewBox="0 0 64 34" width="52" height="28" xmlns="http://www.w3.org/2000/svg" style="overflow: visible;">
                        <g style="transform-origin: 32px 18px; animation: _bank 3.4s ease-in-out infinite;">
                            <path d="M31.5 19C21 8.6 9.2 8.3 2.5 13.2C9.5 14.6 18.9 16.4 31.5 19Z" fill="rgba(255,255,255,0.9)" style="transform-box: fill-box; transform-origin: right center; animation: _wingL 1.05s cubic-bezier(0.37,0,0.63,1) infinite;"/>
                            <path d="M32.5 19C43 8.6 54.8 8.3 61.5 13.2C54.5 14.6 45.1 16.4 32.5 19Z" fill="rgba(255,255,255,0.9)" style="transform-box: fill-box; transform-origin: left center; animation: _wingR 1.05s cubic-bezier(0.37,0,0.63,1) infinite;"/>
                            <path d="M23.5 18.8C26.4 15.2 29.3 13.5 32 13.5C34.8 13.5 37.7 15.2 40.5 18.8C38.1 21.5 35.2 22.8 32 22.8C28.8 22.8 25.9 21.5 23.5 18.8Z" fill="rgba(255,255,255,0.6)"/>
                            <ellipse cx="32" cy="10.2" rx="4.6" ry="3.4" fill="rgba(255,255,255,0.6)"/>
                        </g>
                    </svg>
                    ALBATROS
                </div>
                <h1 data-i18n="auth_hero_title">Join Saudi Arabia's premier real estate circle.</h1>
                <p data-i18n="auth_hero_sub">Whether looking for a new home or listing your properties, get started with ALBATROS today.</p>
            </div>
            <div style="font-size: 13px; opacity: 0.6;">&copy; 2026 ALBATROS Real Estate. All rights reserved.</div>
        </div>
        <div class="auth-form-side">
            <div class="auth-box">
                <h2 data-i18n="create_account">Create Account</h2>
                <div class="subtitle" data-i18n="register_subtitle">Fill in your information to get started</div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert-error">@ViewBag.Error</div>
                }

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    
                    <label style="font-size:12px; font-weight:600; color:#5A5A5A; margin-bottom:8px; display:block; text-transform:uppercase;" data-i18n="account_type">Account Type</label>
                    <div class="role-tabs">
                        <div class="role-tab">
                            <input type="radio" id="roleUser" name="Role" value="User" checked />
                            <label for="roleUser" data-i18n="buyer">Buyer / Tenant</label>
                        </div>
                        <div class="role-tab">
                            <input type="radio" id="roleOwner" name="Role" value="Owner" />
                            <label for="roleOwner" data-i18n="owner">Property Owner</label>
                        </div>
                    </div>

                    <div class="field">
                        <label asp-for="FullName" data-i18n="full_name">Full Name</label>
                        <input asp-for="FullName" type="text" placeholder="John Doe" required />
                        <span asp-validation-for="FullName" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Email" data-i18n="email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="name@example.com" required />
                        <span asp-validation-for="Email" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="field">
                        <label asp-for="PhoneNumber" data-i18n="phone">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" placeholder="+966 50 123 4567" required />
                        <span asp-validation-for="PhoneNumber" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Password" data-i18n="password">Password</label>
                        <input asp-for="Password" type="password" placeholder="••••••••" required />
                        <span asp-validation-for="Password" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>
                    <div class="field">
                        <label asp-for="ConfirmPassword" data-i18n="confirm_password">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required />
                        <span asp-validation-for="ConfirmPassword" style="color:#C62828; font-size:12px; margin-top:4px; display:block;"></span>
                    </div>

                    <button type="submit" class="btn-maroon" data-i18n="register">Register</button>
                </form>

                <div style="display:flex;align-items:center;gap:14px;margin:26px 0;color:var(--text-muted);font-size:12.5px;">
                    <span style="flex:1;height:1px;background:var(--gray-mid);"></span>
                    <span data-i18n="login_or">or continue with</span>
                    <span style="flex:1;height:1px;background:var(--gray-mid);"></span>
                </div>
                <a asp-controller="Account" asp-action="GoogleLogin" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:11px;border-radius:8px;border:1px solid var(--gray-mid);font-size:13px;font-weight:600;color:#4A4A4A;cursor:pointer;background:var(--white);text-decoration:none;margin-bottom:26px;">
                    <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.54 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.87 7.35 2.56 10.58l7.98-5.99z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.99C6.51 42.62 14.62 48 24 48z"/></svg>
                    <span>Google</span>
                </a>
                <div class="auth-links">
                    <span data-i18n="already_account">Already have an account?</span> 
                    <a asp-controller="Account" asp-action="Login" data-i18n="sign_in">Sign In</a>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/i18n.js"></script>
</body>
</html>
