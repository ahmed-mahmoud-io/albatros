@{
    ViewData["Title"] = "About Us";
}

<div class="wrap" style="padding: 60px 0;">
    <div style="max-width: 800px; margin: 0 auto;">
        <div class="eyebrow" data-i18n="about_eyebrow">OUR STORY</div>
        <h1 style="font-size: 40px; font-family: 'Playfair Display', serif; margin-bottom: 24px;" data-i18n="about_title">Redefining Real Estate Excellence in Saudi Arabia</h1>
        
        <p style="font-size: 18px; line-height: 1.8; color: var(--text-muted); margin-bottom: 30px;" data-i18n="about_p1">
            ALBATROS was founded with a singular vision: to bring uncompromising transparency, verified quality, and seamless digital interaction to the Saudi real estate sector.
        </p>

        <div style="background: white; border-radius: 16px; padding: 32px; border: 1px solid #EFEDE9; margin-bottom: 40px;">
            <h3 style="font-size: 22px; margin-bottom: 16px;" data-i18n="about_mission_title">Our Mission</h3>
            <p style="line-height: 1.7; color: var(--black);" data-i18n="about_mission_desc">
                To empower individuals, families, and commercial entities to make confident real estate investments by providing verified listings, accurate market intelligence, and dedicated expert guidance every step of the way.
            </p>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            <div style="background: var(--gray-bg); padding: 24px; border-radius: 12px;">
                <h4 style="font-size: 18px; margin-bottom: 8px; color: var(--maroon);" data-i18n="about_stat1_t">100% Verified</h4>
                <p style="font-size: 14px; color: var(--text-muted);" data-i18n="about_stat1_d">Every listing on ALBATROS passes thorough legal and physical inspections before publication.</p>
            </div>
            <div style="background: var(--gray-bg); padding: 24px; border-radius: 12px;">
                <h4 style="font-size: 18px; margin-bottom: 8px; color: var(--maroon);" data-i18n="about_stat2_t">Kingdom-Wide</h4>
                <p style="font-size: 14px; color: var(--text-muted);" data-i18n="about_stat2_d">Covering prime residential and commercial sectors in Riyadh, Jeddah, Dammam, and beyond.</p>
            </div>
        </div>
    </div>
</div>
