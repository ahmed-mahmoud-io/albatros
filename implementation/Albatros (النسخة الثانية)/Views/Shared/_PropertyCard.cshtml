@model Albatros.Models.Property
@{
    var img = Model.Images?.FirstOrDefault()?.ImageUrl
        ?? "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?q=80&w=800&auto=format&fit=crop";
    var favIds = ViewBag.FavoritedIds as HashSet<int> ?? new HashSet<int>();
    var isFav = favIds.Contains(Model.PropertyId);
    var detailsUrl = Url.Action("Details", "Properties", new { id = Model.PropertyId });
}
<div class="p-card" onclick="location.href='@detailsUrl'" role="link" tabindex="0">
  <div class="p-img" style="background-image:url('@img');">
    <span class="p-tag">@(Model.ListingType == Albatros.Models.ListingType.Sale ? "For Sale" : "For Rent")</span>
    <button class="heart-btn @(isFav ? "active" : "")" data-id="@Model.PropertyId" type="button" aria-label="Toggle favorite" onclick="event.stopPropagation();toggleFav(this, event)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="@(isFav ? "#9C2A2A" : "none")" stroke="#9C2A2A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
  </div>
  <div class="p-body">
    <div class="p-price">@Model.Price.ToString("N0") <span data-i18n="sar">SAR</span></div>
    <div class="p-title">@Model.Title</div>
    <div class="p-loc">📍 @Model.City</div>
    <div class="p-specs">
      <span>@Model.Bedrooms Beds</span>
      <span>@Model.Bathrooms Baths</span>
      <span>@Model.Area m²</span>
    </div>
    <span class="p-btn" data-i18n="view_details">View Details</span>
  </div>
</div>
