@model Albatros.Models.ContactMessage
@{
    ViewData["Title"] = "Message from " + Model.FullName;
}

<div class="admin-card">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px;">
        <h2 style="font-size:20px;">@Model.Subject</h2>
        <span style="font-size:12px; color:#8A8580;">@Model.CreatedAt.ToString("MMM dd, yyyy - HH:mm")</span>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px; padding:16px; background:#F8F8F8; border-radius:8px;">
        <div><strong>Name:</strong> @Model.FullName</div>
        <div><strong>Email:</strong> <a href="mailto:@Model.Email">@Model.Email</a></div>
        <div><strong>Phone:</strong> @Model.Phone</div>
        <div><strong>Subject:</strong> @Model.Subject</div>
    </div>

    <div style="padding:20px; background:#F8F8F8; border-radius:8px; line-height:1.7; white-space:pre-wrap; margin-bottom:24px;">
        @Model.Message
    </div>

    <div style="display:flex; gap:12px;">
        <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn btn-maroon" style="text-decoration:none;">Reply via Email</a>
        <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index" class="btn btn-ghost" style="text-decoration:none;">Back to Inbox</a>
        <form method="post" asp-area="Admin" asp-controller="ContactMessages" asp-action="Delete" asp-route-id="@Model.Id" style="display:inline;" onsubmit="return confirm('Delete this message?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn" style="background:#FFEBEE; color:#C62828; border:none; cursor:pointer;">Delete</button>
        </form>
    </div>
</div>
