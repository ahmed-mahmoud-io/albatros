@model Albatros.Models.VisitRequest
@{
    ViewData["Title"] = "Delete Visit Request";
}

<div class="admin-card" style="max-width:550px; margin:40px auto; text-align:center;">
    <div style="font-size:48px; margin-bottom:16px;">🗑️</div>
    <h1 style="font-size:24px; color:#C62828; margin-bottom:12px;">Delete Tour Booking Record</h1>
    <p style="color:#8A8580; margin-bottom:24px; line-height:1.6;">
        Are you sure you want to permanently delete tour request <strong style="color:#0A0A0A;">#@Model.RequestId</strong> for <strong style="color:#0A0A0A;">@(Model.Property?.Title ?? "Property #" + Model.PropertyId)</strong>?
    </p>

    <div style="background:#F8F8F8; padding:16px; border-radius:10px; margin-bottom:24px; text-align:left;">
        <div><strong>Client:</strong> @(Model.User?.FullName ?? "N/A")</div>
        <div style="margin-top:4px;"><strong>Scheduled Date:</strong> @Model.VisitDate.ToString("MMM dd, yyyy - HH:mm")</div>
    </div>

    <form asp-area="Admin" asp-controller="VisitRequests" asp-action="Delete" asp-route-id="@Model.RequestId" method="post">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; justify-content:center;">
            <button type="submit" class="btn" style="background:#D32F2F; color:white; padding:10px 24px;">Confirm Deletion</button>
            <a asp-area="Admin" asp-controller="VisitRequests" asp-action="Index" class="btn btn-ghost" style="padding:10px 24px;">Cancel</a>
        </div>
    </form>
</div>
