@model Albatros.Models.Review
@{
    ViewData["Title"] = "Review Moderation Details";
}

<div class="admin-card" style="max-width:650px; margin:0 auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #EFEDE9; padding-bottom:20px; margin-bottom:24px;">
        <h1 style="font-size:24px; font-weight:700;">Review #@Model.ReviewId</h1>
        <div style="color:#FFB300; font-size:18px; font-weight:700;">@(new string('★', Model.Rating)) (@Model.Rating / 5)</div>
    </div>

    <div style="margin-bottom:24px; background:#F8F8F8; padding:20px; border-radius:10px;">
        <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600; margin-bottom:8px;">Feedback Content</div>
        <p style="font-size:15px; line-height:1.7; color:#333;">"@Model.Comment"</p>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px;">
        <div>
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600;">Author</div>
            <div style="font-size:15px; font-weight:600; margin-top:4px;">@(Model.User?.FullName ?? "N/A")</div>
            <div style="font-size:13px; color:#8A8580;">@(Model.User?.Email ?? "")</div>
        </div>
        <div>
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600;">Target Property</div>
            <div style="font-size:15px; font-weight:600; margin-top:4px;">
                <a asp-area="Admin" asp-controller="AdminProperties" asp-action="Details" asp-route-id="@Model.PropertyId" style="color:#9C2A2A; text-decoration:none;">@(Model.Property?.Title ?? "Property #" + Model.PropertyId)</a>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:16px; border-top:1px solid #EFEDE9; padding-top:24px;">
        <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="btn btn-ghost" style="padding:10px 20px;">← Back to Reviews</a>
        <a asp-area="Admin" asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.ReviewId" class="btn" style="background:#FFEBEE; color:#C62828; padding:10px 20px;">Delete Review</a>
    </div>
</div>
