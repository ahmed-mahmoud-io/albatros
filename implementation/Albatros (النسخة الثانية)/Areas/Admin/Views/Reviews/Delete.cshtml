@model Albatros.Models.Review
@{
    ViewData["Title"] = "Delete Review";
}

<div class="admin-card" style="max-width:550px; margin:40px auto; text-align:center;">
    <div style="font-size:48px; margin-bottom:16px;">🗑️</div>
    <h1 style="font-size:24px; color:#C62828; margin-bottom:12px;">Delete Feedback Record</h1>
    <p style="color:#8A8580; margin-bottom:24px; line-height:1.6;">
        Are you sure you want to permanently delete review <strong style="color:#0A0A0A;">#@Model.ReviewId</strong> by <strong style="color:#0A0A0A;">@(Model.User?.FullName ?? "User")</strong>?
    </p>

    <div style="background:#F8F8F8; padding:16px; border-radius:10px; margin-bottom:24px; text-align:left;">
        <div style="color:#FFB300; font-weight:700; margin-bottom:6px;">★ @Model.Rating / 5</div>
        <p style="color:#555; font-size:14px; margin:0;">"@Model.Comment"</p>
    </div>

    <form asp-area="Admin" asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.ReviewId" method="post">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; justify-content:center;">
            <button type="submit" class="btn" style="background:#D32F2F; color:white; padding:10px 24px;">Confirm Deletion</button>
            <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="btn btn-ghost" style="padding:10px 24px;">Cancel</a>
        </div>
    </form>
</div>
