@model Albatros.Models.ApplicationUser
@{
    ViewData["Title"] = "User Details";
}

<div class="admin-card" style="max-width:700px; margin:0 auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #EFEDE9; padding-bottom:20px; margin-bottom:24px;">
        <div>
            <h1 style="font-size:24px; font-weight:700;">@Model.FullName</h1>
            <div style="color:#8A8580; font-size:14px; margin-top:4px;">User ID: #@Model.UserId</div>
        </div>
        <span style="padding:6px 14px; border-radius:14px; font-size:13px; font-weight:600; background:@(Model.Role == "Admin" ? "#FFEBEE" : "#E8F5E9"); color:@(Model.Role == "Admin" ? "#C62828" : "#2E7D32");">@Model.Role</span>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px;">
        <div style="background:#F8F8F8; padding:16px; border-radius:10px;">
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600;">Email Address</div>
            <div style="font-size:15px; font-weight:500; margin-top:4px;">@Model.Email</div>
        </div>
        <div style="background:#F8F8F8; padding:16px; border-radius:10px;">
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600;">Phone Number</div>
            <div style="font-size:15px; font-weight:500; margin-top:4px;">@(Model.PhoneNumber ?? "Not provided")</div>
        </div>
    </div>

    @if (Model.Properties != null && Model.Properties.Any())
    {
        <h3 style="font-size:18px; margin-bottom:16px;">Listed Properties (@Model.Properties.Count)</h3>
        <table class="admin-table" style="margin-bottom:28px;">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>City</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Properties)
                {
                    <tr>
                        <td>#@p.PropertyId</td>
                        <td><a asp-area="Admin" asp-controller="AdminProperties" asp-action="Details" asp-route-id="@p.PropertyId" style="color:inherit; font-weight:600; text-decoration:none;">@p.Title</a></td>
                        <td>@p.City</td>
                        <td><span class="status-badge status-@p.Status">@p.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div style="display:flex; gap:16px; border-top:1px solid #EFEDE9; padding-top:24px;">
        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-ghost" style="padding:10px 20px;">← Back to Users List</a>
        @if (Model.Role != "Admin")
        {
            <a asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@Model.UserId" class="btn" style="background:#FFEBEE; color:#C62828; padding:10px 20px;">Delete User</a>
        }
    </div>
</div>
