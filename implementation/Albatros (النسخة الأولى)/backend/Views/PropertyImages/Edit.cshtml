@model Albatros.Models.PropertyImage
@{ ViewData["Title"] = "Edit Image"; }

<h2 style="font-family:'Playfair Display',serif;">Edit Image</h2>

<form asp-controller="PropertyImages" asp-action="Edit" asp-route-id="@Model.ImageId" method="post" style="max-width:480px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ImageId" />
    <input type="hidden" asp-for="PropertyId" />

    <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
    </div>

    <button type="submit" class="btn text-white" style="background:#9C2A2A;">Save Changes</button>
    <a href="/PropertyImages?propertyId=@Model.PropertyId" class="btn btn-outline-secondary">Cancel</a>
</form>
