@model Albatros.Models.Review
@{ ViewData["Title"] = "Write a Review"; }

<h2 style="font-family:'Playfair Display',serif;">Write a Review</h2>

<form asp-controller="Reviews" asp-action="Create" method="post" style="max-width:480px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropertyId" />

    <div class="mb-3">
        <label class="form-label">Rating (1-5)</label>
        <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Comment</label>
        <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
    </div>

    <button type="submit" class="btn text-white" style="background:#9C2A2A;">Submit Review</button>
    <a href="/Properties/Details/@Model.PropertyId" class="btn btn-outline-secondary">Cancel</a>
</form>
