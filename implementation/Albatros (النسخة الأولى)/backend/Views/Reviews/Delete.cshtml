@model Albatros.Models.Review
@{ ViewData["Title"] = "Delete Review"; }

<h2 style="font-family:'Playfair Display',serif;">Delete Review</h2>
<p>Are you sure you want to delete this review?</p>

<form asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.ReviewId" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a href="/Reviews?propertyId=@Model.PropertyId" class="btn btn-outline-secondary">Cancel</a>
</form>
