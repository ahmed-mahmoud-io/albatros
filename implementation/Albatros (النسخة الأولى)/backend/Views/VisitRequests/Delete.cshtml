@model Albatros.Models.VisitRequest
@{ ViewData["Title"] = "Cancel Viewing Request"; }

<h2 style="font-family:'Playfair Display',serif;">Cancel Viewing Request</h2>
<p>Are you sure you want to cancel this viewing request?</p>

<div class="card mb-3" style="max-width:480px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Property?.Title</h5>
        <p class="card-text text-muted">@Model.VisitDate.ToString("MMM d, yyyy h:mm tt")</p>
    </div>
</div>

<form asp-controller="VisitRequests" asp-action="Delete" asp-route-id="@Model.RequestId" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Yes, Cancel It</button>
    <a href="/VisitRequests" class="btn btn-outline-secondary">Keep It</a>
</form>
