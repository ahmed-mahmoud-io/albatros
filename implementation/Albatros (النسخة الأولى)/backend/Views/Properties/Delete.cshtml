@model Albatros.Models.Property
@{ ViewData["Title"] = "Delete Property"; }

<h2 style="font-family:'Playfair Display',serif;">Delete Property</h2>
<p>Are you sure you want to delete this listing? This cannot be undone.</p>

<div class="card mb-3" style="max-width:480px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Title</h5>
        <p class="card-text text-muted">@Model.City &middot; @Model.Price.ToString("N0") SAR</p>
    </div>
</div>

<form asp-controller="Properties" asp-action="Delete" asp-route-id="@Model.PropertyId" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a href="/Properties/Details/@Model.PropertyId" class="btn btn-outline-secondary">Cancel</a>
</form>
