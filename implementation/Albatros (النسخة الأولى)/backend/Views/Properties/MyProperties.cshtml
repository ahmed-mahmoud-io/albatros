@model IEnumerable<Albatros.Models.Property>
@{ ViewData["Title"] = "My Properties"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 style="font-family:'Playfair Display',serif;margin:0;">My Properties</h2>
    <a href="/Properties/Create" class="btn text-white" style="background:#9C2A2A;">+ Add Property</a>
</div>

@if (Model != null && Model.Any())
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>City</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Title</td>
                    <td>@p.City</td>
                    <td>@p.Price.ToString("N0") SAR</td>
                    <td><span class="badge bg-secondary">@p.Status</span></td>
                    <td>
                        <a href="/Properties/Details/@p.PropertyId" class="btn btn-sm btn-outline-secondary">View</a>
                        <a href="/Properties/Edit/@p.PropertyId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a href="/Properties/Delete/@p.PropertyId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">You haven't listed any properties yet.</p>
}
