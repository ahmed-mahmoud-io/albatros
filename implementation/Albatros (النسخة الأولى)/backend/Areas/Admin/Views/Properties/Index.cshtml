@model IEnumerable<Albatros.Models.Property>
@{ ViewData["Title"] = "Manage Properties"; }

<h2 style="font-family:'Playfair Display',serif;">Manage Properties</h2>

<table class="table align-middle mt-3">
    <thead>
        <tr>
            <th>Title</th>
            <th>Owner</th>
            <th>City</th>
            <th>Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Title</td>
                <td>@p.User?.FullName</td>
                <td>@p.City</td>
                <td>@p.Price.ToString("N0") SAR</td>
                <td><span class="badge bg-secondary">@p.Status</span></td>
                <td>
                    <a href="/Admin/Properties/Details/@p.PropertyId" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a href="/Admin/Properties/Edit/@p.PropertyId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a href="/Admin/Properties/Delete/@p.PropertyId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
