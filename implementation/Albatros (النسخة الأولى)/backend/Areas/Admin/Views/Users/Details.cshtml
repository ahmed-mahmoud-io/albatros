@model Albatros.Models.ApplicationUser
@{ ViewData["Title"] = "User Details"; }

<h2 style="font-family:'Playfair Display',serif;">@Model.FullName</h2>

<dl class="row" style="max-width:520px;">
    <dt class="col-sm-4">Email</dt>
    <dd class="col-sm-8">@Model.Email</dd>
    <dt class="col-sm-4">Phone</dt>
    <dd class="col-sm-8">@Model.PhoneNumber</dd>
    <dt class="col-sm-4">Type</dt>
    <dd class="col-sm-8"><span class="badge bg-info text-dark">@Model.UserType</span></dd>
    <dt class="col-sm-4">Role</dt>
    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Role</span></dd>
</dl>

<a href="/Admin/Users" class="btn btn-outline-secondary">Back</a>
