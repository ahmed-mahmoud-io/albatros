@model Albatros.Models.VisitRequest
@{ ViewData["Title"] = "Visit Request Details"; }

<h2 style="font-family:'Playfair Display',serif;">Visit Request</h2>

<dl class="row" style="max-width:520px;">
    <dt class="col-sm-4">Property</dt>
    <dd class="col-sm-8">@Model.Property?.Title</dd>
    <dt class="col-sm-4">Requested By</dt>
    <dd class="col-sm-8">@Model.User?.FullName (@Model.User?.Email)</dd>
    <dt class="col-sm-4">Date</dt>
    <dd class="col-sm-8">@Model.VisitDate.ToString("MMM d, yyyy h:mm tt")</dd>
    <dt class="col-sm-4">Status</dt>
    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Status</span></dd>
</dl>

<a href="/Admin/VisitRequests/Approve/@Model.RequestId" class="btn btn-outline-success">Approve</a>
<a href="/Admin/VisitRequests/Reject/@Model.RequestId" class="btn btn-outline-warning">Reject</a>
<a href="/Admin/VisitRequests" class="btn btn-outline-secondary">Back</a>
