@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="wrap" style="padding: 60px 0;">
    <div style="max-width: 800px; margin: 0 auto; background: white; padding: 40px; border-radius: 16px; border: 1px solid #EFEDE9;">
        <h1 style="font-size: 32px; font-family: 'Playfair Display', serif; margin-bottom: 24px;" data-i18n="privacy_title">Privacy Policy</h1>
        
        <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 20px;">
            At ALBATROS, maintaining the privacy and security of your personal information is fundamental to our service methodology. This policy outlines how we collect, store, and utilize data across our platform.
        </p>

        <h3 style="font-size: 18px; margin: 24px 0 12px; color: var(--black);">1. Information Collection</h3>
        <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 20px;">
            We collect personal details such as name, email address, contact number, and verification documents only when explicitly provided during registration or visit request booking.
        </p>

        <h3 style="font-size: 18px; margin: 24px 0 12px; color: var(--black);">2. Data Protection</h3>
        <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 20px;">
            All authentication credentials are securely hashed using industry-standard cryptography (BCrypt). Your sensitive financial or identity records are never shared with unauthorized third parties.
        </p>

        <h3 style="font-size: 18px; margin: 24px 0 12px; color: var(--black);">3. Cookie Usage</h3>
        <p style="color: var(--text-muted); line-height: 1.8;">
            We utilize secure session cookies exclusively to maintain authentication states and user language preferences across our digital properties.
        </p>
    </div>
</div>
