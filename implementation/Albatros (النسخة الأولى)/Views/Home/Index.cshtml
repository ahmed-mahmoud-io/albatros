@model IEnumerable<Albatros.Models.Property>
@{
    ViewData["Title"] = "Home";
    ViewBag.ShowSplash = true;
}

<!-- HERO SECTION -->
<section class="hero">
  <div class="hero-circles">
    <span style="width:520px;height:520px;top:-180px;right:-120px;"></span>
    <span style="width:340px;height:340px;top:60px;right:80px;"></span>
    <span style="width:200px;height:200px;bottom:-60px;left:-60px;"></span>
  </div>
  <div class="wrap">
    <div class="hero-inner">
      <div>
        <div class="eyebrow" data-i18n="hero_eyebrow">Riyadh · Jeddah · Dammam</div>
        <h1 data-i18n-html="hero_title">Find a home that <em>understands</em> your ambition.</h1>
        <p class="lead" data-i18n="hero_lead">ALBATROS curates the Kingdom's finest residences and investment properties — verified listings, transparent pricing, and a team that closes deals with precision.</p>
        <div class="hero-cta">
          <a asp-controller="Properties" asp-action="Index" class="btn btn-lg btn-maroon" data-i18n="hero_cta1">Explore Properties</a>
          <a asp-controller="Home" asp-action="Contact" class="btn btn-lg btn-outline-black" data-i18n="hero_cta2">Book a Consultation</a>
        </div>
      </div>

      <div class="stats-card">
        <div>
          <div class="stat-num">@(ViewBag.TotalProperties ?? 0)+</div>
          <div class="stat-label" data-i18n="stat1">Properties Available</div>
        </div>
        <div class="stat-divider-v" style="padding-inline-start:24px;">
          <div class="stat-num">@(ViewBag.TotalUsers ?? 0)</div>
          <div class="stat-label" data-i18n="stat2">Registered Users</div>
        </div>
        <div>
          <div class="stat-num">@(ViewBag.TotalCities ?? 0)</div>
          <div class="stat-label" data-i18n="stat3">Cities Covered</div>
        </div>
        <div class="stat-divider-v" style="padding-inline-start:24px;">
          <div class="stat-num">98%</div>
          <div class="stat-label" data-i18n="stat4">Customer Satisfaction</div>
        </div>
      </div>
    </div>

    <!-- PROPERTY CARDS STRIP -->
    <div class="cards-strip" id="properties">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2 style="font-size:24px; font-family:'Playfair Display',serif; color:var(--black);" data-i18n="featured_title">Featured Properties</h2>
        <a asp-controller="Properties" asp-action="Index" style="font-size:14px; color:var(--maroon); font-weight:600; text-decoration:none;" data-i18n="view_all">View All Properties →</a>
      </div>
      <div class="cards-row">
        @if (Model != null && Model.Any())
        {
            @foreach (var property in Model)
            {
                @await Html.PartialAsync("_PropertyCard", property)
            }
        }
        else
        {
            <div style="padding: 40px; text-align: center; color: var(--text-muted); width: 100%; background:white; border-radius:12px; border:1px solid #EFEDE9;">
                <p data-i18n="no_properties">No properties available at the moment. Please check back later.</p>
            </div>
        }
      </div>
    </div>
  </div>
</section>

<!-- WHY ALBATROS / FEATURES SECTION -->
<section class="features" id="features">
  <div class="wrap">
    <div class="section-head">
      <div class="eyebrow" data-i18n="why_eyebrow">Why Albatros</div>
      <h2 data-i18n="why_title">Built for buyers, sellers and investors who move fast.</h2>
    </div>
    <div class="feat-grid">
      <div class="feat-item">
        <div class="feat-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3 11L12 4l9 7M5 10v9a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1v-9" stroke="#9C2A2A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 data-i18n="feat1_h">Verified Listings</h3>
        <p data-i18n="feat1_p">Every property is inspected and legally verified before it appears on ALBATROS.</p>
      </div>
      <div class="feat-item">
        <div class="feat-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="#9C2A2A" stroke-width="1.6" stroke-linecap="round"/></svg>
        </div>
        <h3 data-i18n="feat2_h">Transparent Pricing</h3>
        <p data-i18n="feat2_p">No hidden fees. See market comparisons before you make an offer.</p>
      </div>
      <div class="feat-item">
        <div class="feat-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#9C2A2A" stroke-width="1.6"/><path d="M21 21l-4.35-4.35" stroke="#9C2A2A" stroke-width="1.6" stroke-linecap="round"/></svg>
        </div>
        <h3 data-i18n="feat3_h">Smart Search &amp; Filters</h3>
        <p data-i18n="feat3_p">Narrow thousands of listings by district, budget, size and yield in seconds.</p>
      </div>
      <div class="feat-item">
        <div class="feat-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 21c-4-3.5-8-7-8-11.5A5.5 5.5 0 0112 5a5.5 5.5 0 018 4.5C20 14 16 17.5 12 21z" stroke="#9C2A2A" stroke-width="1.6" stroke-linejoin="round"/></svg>
        </div>
        <h3 data-i18n="feat4_h">Dedicated Advisors</h3>
        <p data-i18n="feat4_p">A personal consultant guides you from first viewing to closing.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="wrap">
    <h2 data-i18n="cta_h">Ready to find your next property?</h2>
    <p data-i18n="cta_p">Book a free consultation with an ALBATROS advisor today.</p>
    <a asp-controller="Home" asp-action="Contact" class="btn btn-lg btn-maroon" data-i18n="hero_cta2">Book a Consultation</a>
  </div>
</section>
