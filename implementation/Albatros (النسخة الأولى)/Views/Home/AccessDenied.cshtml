@{
    ViewData["Title"] = "Access Denied";
}

<div class="wrap" style="padding: 100px 0; text-align: center;">
    <div style="max-width: 500px; margin: 0 auto; background: white; padding: 50px 30px; border-radius: 16px; border: 1px solid #EFEDE9; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
        <div style="font-size: 60px; margin-bottom: 20px;">🔒</div>
        <h1 style="font-size: 28px; font-family: 'Playfair Display', serif; margin-bottom: 12px;" data-i18n="access_denied_title">Access Denied</h1>
        <p style="color: var(--text-muted); margin-bottom: 30px; line-height: 1.6;" data-i18n="access_denied_desc">
            You do not have the necessary permission credentials to view or interact with this requested resource.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-maroon" data-i18n="back_home">Return to Home</a>
    </div>
</div>
