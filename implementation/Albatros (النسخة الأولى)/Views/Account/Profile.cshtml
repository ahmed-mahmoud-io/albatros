@model Albatros.Models.ApplicationUser
@{
    ViewData["Title"] = "Profile";
}

@section Styles {
<style>
    .profile-card {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        border: 1px solid #EFEDE9;
        max-width: 600px;
        margin: 40px auto;
    }
    .profile-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #EFEDE9;
    }
    .profile-avatar {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: var(--maroon);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 700;
    }
    .profile-info h1 { font-size: 24px; margin-bottom: 4px; font-family: 'Playfair Display', serif; }
    .role-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        background: #FFF8E1;
        color: #F57F17;
    }
    .profile-row {
        margin-bottom: 20px;
    }
    .profile-label {
        font-size: 12px;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .profile-value {
        font-size: 16px;
        font-weight: 500;
        color: var(--black);
    }
    .profile-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }
</style>
}

<div class="wrap">
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
            </div>
            <div class="profile-info">
                <h1>@Model.FullName</h1>
                <span class="role-badge">@Model.Role</span>
            </div>
        </div>

        <div class="profile-row">
            <div class="profile-label" data-i18n="email">Email Address</div>
            <div class="profile-value">@Model.Email</div>
        </div>

        <div class="profile-row">
            <div class="profile-label" data-i18n="phone">Phone Number</div>
            <div class="profile-value">@(Model.PhoneNumber ?? "Not provided")</div>
        </div>

        <div class="profile-actions">
            <a asp-controller="Account" asp-action="EditProfile" class="btn btn-maroon" data-i18n="edit_profile">Edit Profile</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-ghost" data-i18n="back_home">Back to Home</a>
        </div>
    </div>
</div>
