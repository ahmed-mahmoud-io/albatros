@{
    var userId = Context.Session.GetInt32("UserId");
    var fullName = Context.Session.GetString("FullName");
    var role = Context.Session.GetString("Role");
    var isLoggedIn = userId != null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - ALBATROS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (ViewBag.ShowSplash == true)
{
<div id="splash">
  <div class="splash-inner">
    <div class="splash-lockup">
      <svg class="splash-bird" viewBox="0 0 48 48" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
        <g class="bird-fly-splash">
          <path class="s-wing s-wing-l" d="M24 24 C10 12, 0 15, 3 27 C10 21, 18 22, 24 24 Z" fill="#FFFFFF"/>
          <path class="s-wing s-wing-r" d="M24 24 C38 12, 48 15, 45 27 C38 21, 30 22, 24 24 Z" fill="#FFFFFF"/>
          <path d="M17 25 Q24 19 31 25 Q28 30 24 30 Q20 30 17 25 Z" fill="rgba(255,255,255,0.7)"/>
        </g>
      </svg>
      <div class="splash-word">ALBATROS</div>
    </div>
    <div class="splash-tag" data-i18n="hero_eyebrow">Riyadh · Jeddah · Dammam</div>
  </div>
  <div class="splash-skip" data-i18n="splash_skip">Click to skip</div>
</div>
}

<header>
  <div class="wrap header-inner">
    <a asp-controller="Home" asp-action="Index" class="logo">
      <span class="logo-mark bird-logo">
        <svg viewBox="0 0 48 48" width="30" height="30" xmlns="http://www.w3.org/2000/svg">
          <g class="bird-fly">
            <path class="wing wing-l" d="M24 24 C10 12, 0 15, 3 27 C10 21, 18 22, 24 24 Z" fill="#9C2A2A"/>
            <path class="wing wing-r" d="M24 24 C38 12, 48 15, 45 27 C38 21, 30 22, 24 24 Z" fill="#9C2A2A"/>
            <path d="M17 25 Q24 19 31 25 Q28 30 24 30 Q20 30 17 25 Z" fill="#7A2020"/>
          </g>
        </svg>
      </span>ALBATROS
    </a>
    <nav>
      <a asp-controller="Home" asp-action="Index" asp-fragment="features" data-i18n="nav_features">Features</a>
      <a asp-controller="Properties" asp-action="Index" data-i18n="nav_properties">Properties</a>
      @if (isLoggedIn)
      {
        <a asp-controller="Favorites" asp-action="Index" data-i18n="nav_favorites">Favorites</a>
      }
      <a asp-controller="Home" asp-action="Contact" data-i18n="nav_contact">Contact</a>
      @if (role == "Owner" || role == "Admin")
      {
        <a asp-controller="Properties" asp-action="MyProperties">My Properties</a>
      }
      @if (role == "Admin")
      {
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
      }
    </nav>
    <div class="header-actions">
      <div class="lang" id="langToggle" role="button" tabindex="0">
        <span id="langLabel">EN</span>
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="#C9C6C1" stroke-width="1.4" stroke-linecap="round"/></svg>
      </div>
      @if (isLoggedIn)
      {
        <a asp-controller="Account" asp-action="Profile" class="btn btn-ghost">@fullName</a>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-maroon">Logout</a>
      }
      else
      {
        <a asp-controller="Account" asp-action="Login" class="btn btn-ghost" data-i18n="nav_login">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-maroon" data-i18n="nav_signup">Sign up</a>
      }
    </div>
  </div>
</header>

@RenderBody()

<footer id="contact">
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-logo">
          <span class="logo-mark bird-logo">
            <svg viewBox="0 0 48 48" width="30" height="30" xmlns="http://www.w3.org/2000/svg">
              <g class="bird-fly">
                <path class="wing wing-l" d="M24 24 C10 12, 0 15, 3 27 C10 21, 18 22, 24 24 Z" fill="#9C2A2A"/>
                <path class="wing wing-r" d="M24 24 C38 12, 48 15, 45 27 C38 21, 30 22, 24 24 Z" fill="#9C2A2A"/>
                <path d="M17 25 Q24 19 31 25 Q28 30 24 30 Q20 30 17 25 Z" fill="#7A2020"/>
              </g>
            </svg>
          </span>ALBATROS
        </div>
        <p class="foot-desc" data-i18n="foot_desc">A premium real estate platform connecting buyers, sellers and investors across Saudi Arabia with verified, high-value properties.</p>
        <div class="foot-social" style="margin-top:22px;"><a href="#">in</a><a href="#">X</a><a href="#">ig</a></div>
      </div>
      <div class="foot-col">
        <h4 data-i18n="foot_links">Quick Links</h4>
        <a asp-controller="Home" asp-action="Index" data-i18n="foot_home">Home</a>
        <a asp-controller="Properties" asp-action="Index" data-i18n="nav_properties">Properties</a>
        <a asp-controller="Home" asp-action="Index" asp-fragment="features" data-i18n="nav_features">Features</a>
        <a asp-controller="Home" asp-action="Contact" data-i18n="nav_contact">Contact</a>
      </div>
      <div class="foot-col">
        <h4 data-i18n="foot_support">Support</h4>
        <a href="#" data-i18n="foot_help">Help Center</a>
        <a asp-controller="Home" asp-action="Privacy" data-i18n="foot_terms">Terms of Service</a>
        <a asp-controller="Home" asp-action="Privacy" data-i18n="foot_privacy">Privacy Policy</a>
        <a href="#" data-i18n="foot_faq">FAQs</a>
      </div>
      <div class="foot-col">
        <h4 data-i18n="foot_contact">Contact</h4>
        <div class="foot-contact-item">✉️ hello@albatros.sa</div>
        <div class="foot-contact-item">📞 +966 11 234 5678</div>
        <div class="foot-contact-item">📍 <span data-i18n="foot_address">King Fahd Road, Riyadh, Saudi Arabia</span></div>
      </div>
    </div>
    <div class="foot-bottom">
      <span data-i18n="foot_rights">© 2026 ALBATROS. All rights reserved.</span>
      <span data-i18n="foot_tagline">Designed for the Saudi real estate market</span>
    </div>
  </div>
</footer>

<script src="~/js/i18n.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
