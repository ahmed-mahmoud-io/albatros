@model IEnumerable<Albatros.Models.Review>
@{
    ViewData["Title"] = "Manage Reviews";
}

<div class="admin-card">
    <h2 style="font-size:20px; margin-bottom:24px;">Client Feedback Moderation</h2>

    @if (Model != null && Model.Any())
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Property</th>
                    <th>Rating</th>
                    <th>Comment Snippet</th>
                    <th>Date</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td style="color:#8A8580; font-size:13px;">#@r.ReviewId</td>
                        <td style="font-weight:600;">@(r.User?.FullName ?? "User")</td>
                        <td>
                            <a asp-area="Admin" asp-controller="AdminProperties" asp-action="Details" asp-route-id="@r.PropertyId" style="color:inherit; text-decoration:none; font-weight:500;">@(r.Property?.Title ?? "Property #" + r.PropertyId)</a>
                        </td>
                        <td style="color:#FFB300; font-weight:700;">★ @r.Rating / 5</td>
                        <td style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#666;">@r.Comment</td>
                        <td style="font-size:13px; color:#8A8580;">@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td style="text-align:right;">
                            <a asp-area="Admin" asp-controller="Reviews" asp-action="Details" asp-route-id="@r.ReviewId" class="btn btn-ghost" style="padding:6px 12px; font-size:12px; text-decoration:none;">Details</a>
                            <a asp-area="Admin" asp-controller="Reviews" asp-action="Delete" asp-route-id="@r.ReviewId" class="btn" style="padding:6px 12px; font-size:12px; background:#FFEBEE; color:#C62828; text-decoration:none;">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="padding:40px; text-align:center; color:#8A8580;">No reviews recorded in the database.</p>
    }
</div>
