@model Albatros.Models.VisitRequest
@{
    ViewData["Title"] = "Visit Request Moderation";
}

<div class="admin-card" style="max-width:700px; margin:0 auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #EFEDE9; padding-bottom:20px; margin-bottom:24px;">
        <div>
            <h1 style="font-size:24px; font-weight:700;">Tour Booking #@Model.RequestId</h1>
            <div style="color:#8A8580; font-size:14px; margin-top:4px;">Requested Time: @Model.VisitDate.ToString("dddd, MMM dd, yyyy - HH:mm")</div>
        </div>
        <span class="status-badge status-@Model.Status" style="font-size:14px; padding:6px 16px;">@Model.Status</span>
    </div>

    <!-- MODERATION ACTION BAR -->
    <div style="background:#F5F6FA; padding:20px; border-radius:12px; margin-bottom:28px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
        <div>
            <div style="font-weight:600; font-size:15px;">Tour Confirmation Status</div>
            <div style="font-size:13px; color:#8A8580;">Approve to confirm advisor assignment, or Reject if time slot is unavailable.</div>
        </div>
        <div style="display:flex; gap:12px;">
            <form asp-area="Admin" asp-controller="VisitRequests" asp-action="Approve" asp-route-id="@Model.RequestId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn" style="background:#2E7D32; color:white; padding:10px 20px; font-weight:600; border:none; border-radius:8px; cursor:pointer;">✅ Approve Booking</button>
            </form>
            <form asp-area="Admin" asp-controller="VisitRequests" asp-action="Reject" asp-route-id="@Model.RequestId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn" style="background:#C62828; color:white; padding:10px 20px; font-weight:600; border:none; border-radius:8px; cursor:pointer;">❌ Reject Booking</button>
            </form>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px;">
        <div style="background:#F8F8F8; padding:16px; border-radius:10px;">
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600; margin-bottom:8px;">Target Property</div>
            <div style="font-size:16px; font-weight:700;">
                <a asp-area="Admin" asp-controller="AdminProperties" asp-action="Details" asp-route-id="@Model.PropertyId" style="color:#9C2A2A; text-decoration:none;">@(Model.Property?.Title ?? "Property #" + Model.PropertyId)</a>
            </div>
        </div>

        <div style="background:#F8F8F8; padding:16px; border-radius:10px;">
            <div style="font-size:12px; color:#8A8580; text-transform:uppercase; font-weight:600; margin-bottom:8px;">Client Details</div>
            <div><strong>Name:</strong> @(Model.User?.FullName ?? "N/A")</div>
            <div><strong>Email:</strong> @(Model.User?.Email ?? "N/A")</div>
            <div><strong>Phone:</strong> @(Model.User?.PhoneNumber ?? "N/A")</div>
        </div>
    </div>

    <div style="display:flex; gap:16px; border-top:1px solid #EFEDE9; padding-top:24px;">
        <a asp-area="Admin" asp-controller="VisitRequests" asp-action="Index" class="btn btn-ghost" style="padding:10px 20px;">← Back to Requests</a>
        <a asp-area="Admin" asp-controller="VisitRequests" asp-action="Delete" asp-route-id="@Model.RequestId" class="btn" style="background:#FFEBEE; color:#C62828; padding:10px 20px;">Delete Record</a>
    </div>
</div>
