# .editorconfig - Project coding style and formatting
root = true

[*]
charset = utf-8-bom
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,cshtml}]
indent_style = space
indent_size = 4
charset = utf-8
end_of_line = crlf

# C# specific rules
[*.cs]
# Use four spaces
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_new_line_before_open_brace = all
csharp_prefer_braces = true:suggestion

# Naming conventions
dotnet_naming_rule.private_fields_should_be_camel_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_with_underscore.style = camel_with_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_with_underscore.capitalization = camel_case
dotnet_naming_style.camel_with_underscore.required_prefix = _

# Use expression-bodied members when possible
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# File header
file_header_template = ""

[*.cshtml]
indent_style = space
indent_size = 4

# Ensure JSON files use 2-space indent
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# End of .editorconfig